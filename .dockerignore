# Elixir build artifacts
_build/
deps/
*.ez

# Generated on crash by the VM
erl_crash.dump

# Static artifacts
node_modules/
assets/node_modules/

# esbuild output and the digest manifest are regenerated in-image by
# `mix assets.deploy`, so they are not part of the build context. Source static
# files (fonts, icons, manifest.webmanifest, sw.js, robots.txt) ARE kept: they
# are committed and `COPY priv priv` must include them.
priv/static/assets/
priv/static/cache_manifest.json

# Ignore package manager files
.npm
.yarn

# Ignore development and test files
.git
.gitignore
.dockerignore
.env*
.vscode/
.idea/

# Database
*.db
*.sqlite

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# Documentation
/doc/
/docs/

# Coverage
cover/
*.coverdata

# Test artifacts
test/tmp/
tmp/

# Dialyzer
priv/plts/
